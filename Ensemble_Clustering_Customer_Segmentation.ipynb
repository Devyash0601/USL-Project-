   "source": [
    "## Co-Association Matrix (Core Research Component)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Co-Association Matrix shape: (200, 200)\n",
      "Value range: [0.000, 1.000]\n",
      "Mean co-association: 0.3153\n"
     ]
    }
   ],
   "source": [
    "def build_coassociation_matrix(label_list, n_samples):\n",
    "    \"\"\"\n",
    "    Build co-association matrix from a list of label arrays.\n",
    "    \n",
    "    Co-association(i, j) = (# times i and j are in same cluster) / total_runs\n",
    "    Points labelled as noise (-1 in DBSCAN) are excluded from co-occurrence.\n",
    "    \"\"\"\n",
    "    M = np.zeros((n_samples, n_samples), dtype=np.float32)\n",
    "    total_runs = len(label_list)\n",
    "\n",
    "    for labels in label_list:\n",
    "        for cluster_id in np.unique(labels):\n",
    "            if cluster_id == -1:     # skip noise\n",
    "                continue\n",
    "            idx = np.where(labels == cluster_id)[0]\n",
    "            # All pairs within same cluster get +1\n",
    "            M[np.ix_(idx, idx)] += 1\n",
    "\n",
    "    M /= total_runs\n",
    "    np.fill_diagonal(M, 1.0)        # self-similarity = 1\n",
    "    return M\n",
    "\n",
    "\n",
    "n = X_scaled.shape[0]\n",
    "all_labels = [labels_kmeans, labels_agglo, labels_dbscan]\n",
    "\n",
    "co_matrix = build_coassociation_matrix(all_labels, n)\n",
    "\n",
    "print(f'Co-Association Matrix shape: {co_matrix.shape}')\n",
    "print(f'Value range: [{co_matrix.min():.3f}, {co_matrix.max():.3f}]')\n",
    "print(f'Mean co-association: {co_matrix.mean():.4f}')"
   ]
  },
