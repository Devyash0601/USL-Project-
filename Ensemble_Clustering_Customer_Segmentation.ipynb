      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Convert co-association to distance matrix for linkage\n",
    "distance_matrix = 1 - co_matrix\n",
    "np.fill_diagonal(distance_matrix, 0)\n",
    "\n",
    "# Use condensed distance form\n",
    "from scipy.spatial.distance import squareform\n",
    "condensed_dist = squareform(distance_matrix)\n",
    "\n",
    "Z = linkage(condensed_dist, method='average')\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(14, 5))\n",
    "dendrogram(\n",
    "    Z, ax=ax,\n",
    "    truncate_mode='lastp',\n",
    "    p=30,\n",
    "    leaf_rotation=90,\n",
    "    leaf_font_size=8,\n",
    "    show_contracted=True,\n",
    "    color_threshold=0.5\n",
    ")\n",
    "ax.set_title('Dendrogram from Co-Association Distance Matrix', fontweight='bold', fontsize=12)\n",
    "ax.set_xlabel('Customer Samples')\n",
    "ax.set_ylabel('Distance (1 - Co-Association Score)')\n",
    "ax.axhline(y=0.5, color='red', linestyle='--', alpha=0.6, label='Cut threshold')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
