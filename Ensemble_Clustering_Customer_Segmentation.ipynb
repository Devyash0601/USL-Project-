   "source": [
    "def evaluate_clustering(X, labels, name):\n",
    "    \"\"\"Compute Silhouette Score and Davies-Bouldin Index.\n",
    "    Skips noise points (-1) for DBSCAN.\"\"\"\n",
    "    valid_mask = labels != -1\n",
    "    X_v = X[valid_mask]\n",
    "    l_v  = labels[valid_mask]\n",
    "\n",
    "    n_unique = len(np.unique(l_v))\n",
    "    if n_unique < 2:\n",
    "        return {'Algorithm': name, 'Silhouette ↑': 'N/A', 'Davies-Bouldin ↓': 'N/A', 'Clusters': n_unique}\n",
    "\n",
    "    sil = silhouette_score(X_v, l_v)\n",
    "    db  = davies_bouldin_score(X_v, l_v)\n",
    "    return {'Algorithm': name, 'Silhouette ↑': round(sil, 4),\n",
    "            'Davies-Bouldin ↓': round(db, 4), 'Clusters': n_unique}\n",
    "\n",
    "results = [\n",
    "    evaluate_clustering(X_scaled, labels_kmeans,  'K-Means'),\n",
    "    evaluate_clustering(X_scaled, labels_agglo,   'Agglomerative'),\n",
    "    evaluate_clustering(X_scaled, labels_dbscan,  'DBSCAN'),\n",
    "    evaluate_clustering(X_scaled, labels_ensemble,'Ensemble (Consensus)'),\n",
    "]\n",
    "\n",
    "results_df = pd.DataFrame(results).set_index('Algorithm')\n",
    "print('='*60)\n",
    "print('          PERFORMANCE METRICS COMPARISON')\n",
    "print('='*60)\n",
    "print(results_df.to_string())\n",
    "print('\\n(↑ higher Silhouette = better | ↓ lower Davies-Bouldin = better)')"
   ]
  },
