    "axes[1].set_title('Distribution of Co-Association Values', fontweight='bold')\n",
    "axes[1].set_xlabel('Co-association Score (0 = never together, 1 = always together)')\n",
    "axes[1].set_ylabel('Frequency')\n",
    "axes[1].axvline(flat.mean(), color='red', linestyle='--',\n",
    "                label=f'Mean = {flat.mean():.3f}')\n",
    "axes[1].legend()\n",
    "\n",
    "plt.suptitle('Co-Association Matrix Analysis', fontsize=13, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
