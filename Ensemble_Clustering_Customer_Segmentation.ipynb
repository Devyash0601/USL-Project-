    "    'Agglo + DBSCAN':          [labels_agglo,  labels_dbscan],\n",
    "    'All Three (Full Ensemble)':[labels_kmeans, labels_agglo, labels_dbscan],\n",
    "}\n",
    "\n",
    "for name, label_list in combos.items():\n",
    "    M = build_coassociation_matrix(label_list, n)\n",
    "    D = 1 - M\n",
    "    np.fill_diagonal(D, 0)\n",
    "    agg = AgglomerativeClustering(n_clusters=N_CLUSTERS, metric='precomputed', linkage='average')\n",
    "    lbl = agg.fit_predict(D)\n",
    "    res = evaluate_clustering(X_scaled, lbl, name)\n",
    "    ablation_results.append(res)\n",
    "\n",
    "ablation_df = pd.DataFrame(ablation_results).set_index('Algorithm')\n",
    "print('=== Ablation Study: Effect of Removing One Algorithm ===')\n",
    "print(ablation_df.to_string())"
   ]
