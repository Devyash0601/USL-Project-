  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Optimal K Selection (Elbow Method)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1680x480 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Best silhouette K: 6 | Score: 0.4284\n"
     ]
    }
   ],
   "source": [
    "inertias = []\n",
    "sil_scores = []\n",
    "K_range = range(2, 11)\n",
    "\n",
    "for k in K_range:\n",
    "    km = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
    "    labels = km.fit_predict(X_scaled)\n",
    "    inertias.append(km.inertia_)\n",
    "    sil_scores.append(silhouette_score(X_scaled, labels))\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 4))\n",
    "\n",
    "ax1.plot(K_range, inertias, 'o-', color='#4C72B0', linewidth=2, markersize=7)\n",
    "ax1.set_title('Elbow Method — Inertia', fontweight='bold')\n",
    "ax1.set_xlabel('Number of Clusters (K)')\n",
    "ax1.set_ylabel('Inertia')\n",
    "ax1.axvline(x=5, color='red', linestyle='--', alpha=0.7, label='Chosen K=5')\n",
    "ax1.legend()\n",
    "\n",
    "ax2.plot(K_range, sil_scores, 's-', color='#DD8452', linewidth=2, markersize=7)\n",
    "ax2.set_title('Silhouette Score vs K', fontweight='bold')\n",
    "ax2.set_xlabel('Number of Clusters (K)')\n",
    "ax2.set_ylabel('Silhouette Score')\n",
    "ax2.axvline(x=5, color='red', linestyle='--', alpha=0.7, label='Chosen K=5')\n",
    "ax2.legend()\n",
    "\n",
    "plt.suptitle('Optimal K Selection', fontsize=13, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "🎯 Using N_CLUSTERS = 5 for all algorithms\n"
     ]
    }
   ],
   "source": [
    "# Set global K for comparable algorithms\n",
    "N_CLUSTERS = 5\n",
